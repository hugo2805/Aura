<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AuraUpdater.MainWindow"
        Width="380" Height="280"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <Style Selector="Image#Needle">
            <Style.Animations>
                <Animation Duration="0:0:1.8"
                           IterationCount="INFINITE"
                           Easing="CubicEaseInOut"
                           FillMode="Both">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Grid>
        <!-- Image de fond fixe -->
        <Image Source="avares://AuraInstaller/Assets/bkgd.png" Stretch="Fill" />

        <!-- Aiguille qui tourne au centre -->
        <Image x:Name="Needle"
               Source="avares://AuraInstaller/Assets/Aiguille.png"
               Width="8" Height="35"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0,144,0,0"
               RenderTransformOrigin="50%,50%">
            <Image.RenderTransform>
                <RotateTransform Angle="0"/>
            </Image.RenderTransform>
        </Image>

        <!-- Zone info UI en bas -->
        <StackPanel VerticalAlignment="Bottom"
                    Margin="0,0,0,5"
                    HorizontalAlignment="Center">
            <TextBlock x:Name="Status"
                       Text="Vérification des mises à jour…"
                       Foreground="White"
                       FontSize="14"
                       HorizontalAlignment="Center"/>
            <ProgressBar x:Name="Bar"
                         Width="300" Height="8"
                         Margin="0,16,0,0"
                         Minimum="0" Maximum="100"/>
            <TextBlock x:Name="Pct"
                       Text="0 %"
                       Foreground="#CCCCCC"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>
    </Grid>
</Window>